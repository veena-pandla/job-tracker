# Copy this file to .env and fill in your values

# Groq API key (free — get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# LinkedIn credentials (for Easy Apply automation)
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password_here

# Indeed credentials (for Quick Apply automation)
INDEED_EMAIL=your_email@example.com
INDEED_PASSWORD=your_password_here

# Job search settings
JOB_KEYWORDS=machine learning engineer,AI engineer,data scientist,ML engineer
JOB_LOCATION=Remote
MIN_SCORE_TO_APPLY=7
MAX_APPLICATIONS_PER_RUN=10
